# ─── Nomba API credentials ────────────────────────────────────────────────────
# Get these from the Nomba dashboard after KYC/KYB approval.
# Sandbox base URL is used by default — switch to production when ready.

NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here
NOMBA_ACCOUNT_ID=your_account_id_here

# Sandbox (default when NOMBA_BASE_URL is unset):
#   https://api.nomba.com/v1
# Production:
#   https://api.nomba.com/v1
# (Nomba uses the same base URL; environment is determined by your credentials)
NOMBA_BASE_URL=https://api.nomba.com/v1

# Webhook secret — copy from the Nomba dashboard webhook settings
NOMBA_WEBHOOK_SECRET=your_webhook_secret_here
