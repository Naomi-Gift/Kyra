# ── Chain ──────────────────────────────────────────────────────────────────────
CELO_RPC_URL=https://forno.celo.org

# ── Agent wallet ────────────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=0x...

# ── Contract ────────────────────────────────────────────────────────────────────
KYRA_VAULT_ADDRESS=0x...
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# ── Schedule (default: 08:00 UTC daily) ─────────────────────────────────────────
CRON_SCHEDULE=0 8 * * *

# ── Frontend URL (used in email CTAs) ───────────────────────────────────────────
PUBLIC_URL=https://kyra.xyz

# ── Email (Resend) ───────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@kyra.xyz

# ── Member email registry (JSON: address → email) ────────────────────────────────
# MEMBER_EMAILS={"0xabc...":"alice@example.com","0xdef...":"bob@example.com"}
MEMBER_EMAILS={}

# ── Telegram (optional) ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
