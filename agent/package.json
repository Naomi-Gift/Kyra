    "dotenv": "16.4.5",
    "pino":   "9.3.2",
    "pino-pretty": "11.2.1",
    "node-cron": "3.0.3"
  },
  "devDependencies": {
    "@types/node":      "20.14.2",
    "@types/node-cron": "3.0.11",
    "tsx":              "4.15.7",
    "typescript":       "5.4.5"
  }
}
