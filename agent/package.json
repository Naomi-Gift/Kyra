{
  "name": "choreagent-backend",
  "version": "1.0.0",
  "description": "Off-chain automation agent for ChoreAgent savings circles",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev":   "tsx watch src/index.ts",
    "start": "node --loader tsx src/index.ts",
